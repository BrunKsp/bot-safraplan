# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados (sessões WhatsApp <-> cliente + histórico de conversa, schema `chat`)
# Use DATABASE_URL (connection string única — docker-compose local, Postgres gerenciado do Render)
# OU DB_HOST/DB_PORT/DB_USER/DB_PASS/DB_NAME (variáveis discretas — provedores externos como Neon,
# mesmo padrão do backend-safraplan). Se DB_HOST estiver definido, ele tem prioridade.
DATABASE_URL=postgresql://bot_user:bot_password@localhost:5432/bot_safraplan
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASS=
# DB_NAME=
# DB_SSL=true

# WHATSAPP_PROVIDER = waha (dev local, via docker-compose) | meta (produção, API oficial)
WHATSAPP_PROVIDER=meta

# WAHA (WhatsApp HTTP API) - usada só quando WHATSAPP_PROVIDER=waha - https://waha.devlike.pro
WAHA_URL=http://localhost:3001
WAHA_API_KEY=troque-esta-chave
WAHA_SESSION=default
# Login do dashboard/swagger da WAHA (http://localhost:3001/dashboard) — sem isso a WAHA gera uma
# senha aleatória nova a cada start (fica só no log do container).
# Use uma senha forte — a WAHA ignora senhas fracas (ex: "admin") e gera uma aleatória por conta própria nesse caso.
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=troque-por-uma-senha-forte-e-aleatoria
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=troque-por-uma-senha-forte-e-aleatoria
# Segredo usado para validar que a chamada ao webhook veio da sua instância WAHA
# (configurado como query string na URL do webhook: http://bot:3000/webhook/whatsapp?token=SEU_SEGREDO)
WEBHOOK_SECRET=troque-este-segredo

# Meta WhatsApp Cloud API - usada só quando WHATSAPP_PROVIDER=meta - https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_API_VERSION=v21.0
# Token de acesso permanente (System User com permissão whatsapp_business_messaging)
WHATSAPP_TOKEN=
# ID do número de telefone (WhatsApp > API Setup, no painel do app na Meta)
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (WABA) — não usado pelo código hoje, guardado como referência
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Valor que você escolhe e configura também no painel da Meta (Webhook > Verify token)
WHATSAPP_VERIFY_TOKEN=troque-este-verify-token
# App Secret (Configurações do app > Básico) — usado para validar a assinatura (X-Hub-Signature-256) do webhook
WHATSAPP_APP_SECRET=

# backend-safraplan
BACKEND_API_URL=https://backend-safraplan.onrender.com/api/v1
# Precisa ser IDÊNTICO ao WHATSAPP_BOT_SECRET configurado no backend-safraplan
WHATSAPP_BOT_SECRET=troque-este-segredo-compartilhado-com-o-backend

# IA — AI_PROVIDER = openai | anthropic | nvidia
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# NVIDIA NIM (endpoint compatível com OpenAI) - https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
